<% if render_as_link? %>
  <%= tag.a @label,
        href: @href,
        class: "btn #{variant_class} #{@html_options[:class]}".strip,
        "data-turbo-method": @method&.to_s,
        disabled: disabled? || nil,
        **@html_options.except(:class) %>
<% else %>
  <%= tag.button @label,
        type: @type,
        class: "btn #{variant_class} #{@loading ? 'loading' : ''} #{@html_options[:class]}".strip,
        disabled: disabled? || nil,
        **@html_options.except(:class) %>
<% end %>
