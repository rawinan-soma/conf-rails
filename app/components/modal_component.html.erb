<dialog id="<%= @id %>"
        class="modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="<%= @id %>-title"
        data-controller="modal">
  <div class="modal-box" style="border-radius: var(--radius-lg); box-shadow: var(--shadow-3);">
    <div class="flex items-center justify-between mb-4 pb-3" style="background-color: var(--color-green-900); margin: -1.5rem -1.5rem 1rem; padding: 1rem 1.5rem; border-radius: var(--radius-lg) var(--radius-lg) 0 0;">
      <h3 id="<%= @id %>-title" class="font-semibold text-lg" style="color: white;"><%= @title %></h3>
      <button onclick="document.getElementById('<%= @id %>').close()"
              class="btn btn-ghost btn-sm"
              style="color: white;"
              aria-label="<%= t('components.modal.close_label') %>">
        &#x2715;
      </button>
    </div>
    <% if body %>
      <div class="modal-body">
        <%= body %>
      </div>
    <% end %>
    <% if footer %>
      <div class="modal-action mt-4">
        <%= footer %>
      </div>
    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button><%= t('common.close') %></button>
  </form>
</dialog>
