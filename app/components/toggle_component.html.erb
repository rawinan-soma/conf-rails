<div class="form-control">
  <label class="label cursor-pointer gap-3 justify-start">
    <% if @form && @attribute %>
      <%= @form.check_box @attribute, class: "toggle toggle-primary", **@html_options %>
    <% else %>
      <input type="checkbox"
             class="toggle toggle-primary"
             <%= 'checked' if checked? %>
             <%= tag.attributes(@html_options) %>>
    <% end %>
    <span class="label-text"><%= @label %></span>
  </label>
</div>
