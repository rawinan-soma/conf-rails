<% @rows.times do %>
  <% if @variant == :card %>
    <div class="skeleton h-32 w-full rounded" style="border-radius: var(--radius-md);"></div>
  <% elsif @variant == :list_row %>
    <div class="skeleton flex gap-4 items-center h-8 w-full rounded"></div>
  <% elsif @variant == :table_row %>
    <div class="skeleton h-4 w-full rounded"></div>
  <% elsif @variant == :calendar_grid %>
    <div class="skeleton h-32 w-full rounded" style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.25rem;"></div>
  <% end %>
<% end %>
